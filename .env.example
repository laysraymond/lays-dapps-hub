# Supabase PostgreSQL connection strings (set these as Replit Secrets)
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Session secret (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-32-char-string!!
